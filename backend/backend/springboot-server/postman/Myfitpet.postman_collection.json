        }
      },
      "response": []
    },
    {
      "name": "Yoga - Stop Session",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/yoga/session/stop",
          "host": ["{{baseUrl}}"],
          "path": ["api", "yoga", "session", "stop"]
        },
        "body": {

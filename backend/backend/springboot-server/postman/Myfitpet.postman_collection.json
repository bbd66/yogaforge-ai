          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/yoga/session/frame",
          "host": ["{{baseUrl}}"],
          "path": ["api", "yoga", "session", "frame"]
        },
        "body": {
          "mode": "raw",

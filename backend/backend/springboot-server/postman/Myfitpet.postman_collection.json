{
  "info": {
    "_postman_id": "b7d9a0f0-0000-0000-0000-myfitpet-collection",
    "name": "MyFitPet Backend Flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "register"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test1@example.com\",\n  \"username\": \"test1\",\n  \"password\": \"123456\",\n  \"avatarUrl\": null\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  const data = pm.response.json();",
              "  if (data.token) {",
              "    pm.environment.set(\"token\", data.token);",
              "  }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test1@example.com\",\n  \"password\": \"123456\"\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  const data = pm.response.json();",
              "  if (data.token) {",
              "    pm.environment.set(\"token\", data.token);",
              "  }",
              "}",
              ""
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Pets - Get My Pet (/api/pets/me)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/pets/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "pets", "me"]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  const data = pm.response.json();",
              "  if (data.id) {",
              "    pm.environment.set(\"petId\", String(data.id));",
              "  }",
              "}",
              ""
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Yoga - Start Session",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/yoga/session/start",
          "host": ["{{baseUrl}}"],
          "path": ["api", "yoga", "session", "start"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"expectedPose\": \"warrior_ii\"\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  const data = pm.response.json();",
              "  if (data.sessionId) {",
              "    pm.environment.set(\"sessionId\", String(data.sessionId));",
              "  }",
              "}",
              ""
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
